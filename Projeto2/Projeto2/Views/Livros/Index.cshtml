@model Projeto2.Models.Livro

@{
    ViewBag.Title = "Cadastrar Novo Usuario";
}

<h2 style="text-align:center;">Novo Usuario</h2>

<div class="center">
    @using (Html.BeginForm("Index", "Livro", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <div class="form-horizontal">
            <hr>
            @Html.ValidationSummary(true, "", new { @class = "text-danger"})

            <div class="form-group space-around-flex">
                @Html.LabelFor(model => model.NomeLivro, htmlAttributes: new {@class = "control-label col-md-2"})
            </div>

            <div class="col-md-10">
                @Html.EditorFor(model => model.NomeLivro, new { htmlAtributes = new { @class = "form-group"} })
                @Html.ValidationMessageFor(model => model.NomeLivro, "", new { @class = "text-danger"})
            </div>
        </div>

        <div class="form-group-center">
            <div>
                <label class="control-label col-md-2" for="file">Capa Livro</label>
            </div>
            <div class="col-md-10">
                <input type="file" name="file" id="file" /> <br />
            </div>
        </div>

        <div class="form-group center">
            <div class="col-md-10">
                @ViewBag.msg<br />
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="SalvarProduto" class="btn btn-success"/>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
